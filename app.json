{
  "expo": {
    "name": "cozy-anomaly-mobile",
    "slug": "cozy-anomaly-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "cozyanomalymobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
